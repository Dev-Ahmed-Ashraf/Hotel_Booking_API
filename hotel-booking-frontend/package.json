{
  "name": "hotel-booking-frontend",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "start": "ng serve customer-portal",
    "start:customer": "ng serve customer-portal --port 4200",
    "start:admin": "ng serve admin-dashboard --port 4201",
    "build": "ng build",
    "build:customer": "ng build customer-portal",
    "build:admin": "ng build admin-dashboard",
    "generate:api": "ng-openapi-gen -c tools/openapi/ng-openapi-gen.json",
    "watch": "ng build --watch --configuration development",
    "test": "ng test",
    "e2e": "playwright test",
    "e2e:ui": "playwright test --ui",
    "e2e:install": "playwright install chromium"
  },
  "private": true,
  "dependencies": {
    "@angular/animations": "^19.2.22",
    "@angular/cdk": "^19.2.19",
    "@angular/common": "^19.2.0",
    "@angular/compiler": "^19.2.0",
    "@angular/core": "^19.2.0",
    "@angular/forms": "^19.2.0",
    "@angular/material": "^19.2.19",
    "@angular/platform-browser": "^19.2.0",
    "@angular/platform-browser-dynamic": "^19.2.0",
    "@angular/router": "^19.2.0",
    "@jsverse/transloco": "^8.3.0",
    "@jsverse/transloco-messageformat": "^8.3.0",
    "@stripe/stripe-js": "^9.6.0",
    "jwt-decode": "^4.0.0",
    "rxjs": "~7.8.0",
    "tslib": "^2.3.0",
    "zone.js": "~0.15.0"
  },
  "devDependencies": {
    "@angular-devkit/build-angular": "^19.2.26",
    "@angular/cli": "^19.2.26",
    "@angular/compiler-cli": "^19.2.0",
    "@playwright/test": "^1.52.0",
    "@tailwindcss/postcss": "^4.3.0",
    "@types/jasmine": "~5.1.0",
    "jasmine-core": "~5.6.0",
    "karma": "~6.4.0",
    "karma-chrome-launcher": "~3.2.0",
    "karma-coverage": "~2.2.0",
    "karma-jasmine": "~5.1.0",
    "karma-jasmine-html-reporter": "~2.1.0",
    "ng-openapi-gen": "^1.0.5",
    "ng-packagr": "^19.2.0",
    "postcss": "^8.5.15",
    "tailwindcss": "^4.3.0",
    "typescript": "~5.7.2"
  }
}
